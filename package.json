{
  "name": "facet",
  "private": true,
  "version": "0.1.1",
  "license": "AGPL-3.0-or-later",
  "packageManager": "bun@1.3.9",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun --filter @facet/web dev",
    "dev:local": "bun scripts/local-dev.ts",
    "build": "bun run build:packages && bun --filter @facet/web build",
    "build:relay-policy": "bun build packages/strfry-policy/src/node-entry.ts --target=node --format=cjs --banner='#!/usr/bin/env node' --outfile=deploy/facet-allowlist.js",
    "build:packages": "bun --filter './packages/*' build",
    "check": "bun run typecheck && bun run lint && bun run test",
    "typecheck": "bun --filter '*' typecheck",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "test": "bun --filter '*' test",
    "test:strfry": "bun run build:relay-policy && bun --filter @facet/strfry-policy test -- --run src/strfry.integration.test.ts",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "policy": "bun --filter @facet/strfry-policy start",
    "relay:local:up": "bun run build:relay-policy && docker compose -f compose.local.yml up --build --detach --wait relay",
    "relay:local:down": "docker compose -f compose.local.yml down",
    "relay:local:logs": "docker compose -f compose.local.yml logs --follow relay",
    "relay:local:reset": "docker compose -f compose.local.yml down --volumes",
    "import:outline": "bun --filter @facet/importer import:outline",
    "import:flutter": "bun --filter @facet/importer import:flutter"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.10.2",
    "@biomejs/biome": "2.2.5",
    "@playwright/test": "1.55.1",
    "@types/bun": "1.3.9",
    "nostr-tools": "2.17.0",
    "typescript": "5.9.2",
    "vitest": "3.2.4"
  }
}
